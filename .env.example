# MiroTrade Framework — Environment Configuration
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# ── MT5 / Vantage Credentials ──────────────────────────────
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=Vantage-Server-Name

# ── Trading Parameters ──────────────────────────────────────
PRIMARY_SYMBOL=XAUUSD
TIMEFRAME=H1
MAX_RISK_PER_TRADE=0.01         # 1% risk per trade
MAX_DAILY_DRAWDOWN=0.05         # 5% daily max drawdown
MAX_TOTAL_DRAWDOWN=0.15         # 15% total max drawdown
MIN_CONFLUENCE_SCORE=12         # Minimum score to trigger trade (out of 20)

# ── AI / LLM ────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o

# ── News Feed ───────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mirotrade
REDIS_URL=redis://localhost:6379

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_PORT=3000
BACKEND_PORT=8000
